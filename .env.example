# Google Maps API 키
# Google Cloud Console(https://console.cloud.google.com/apis/credentials)에서 발급받으세요
# 1. API 및 서비스 → 사용자 인증 정보 → API 키 만들기
# 2. Maps JavaScript API 활성화 필요
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# 카카오 지도 API 키 (현재 사용 안함 - Google Maps로 변경됨)
# REACT_APP_KAKAO_MAPS_API_KEY=your_kakao_api_key_here

# 기존 네이버 지도 API (사용 안함)
# REACT_APP_NAVER_MAPS_CLIENT_ID=your_naver_client_id